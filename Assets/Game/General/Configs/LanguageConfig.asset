  kvStringsLocalizations:
  - localizationKey: 0
    localizationValues:
    - Level
    - "\u0423\u0440\u043E\u0432\u0435\u043D\u044C"
  - localizationKey: 1
    localizationValues:
    - Press On The Screen
    - "\u041D\u0430\u0436\u043C\u0438 \u041D\u0430 \u042D\u043A\u0440\u0430\u043D"
  - localizationKey: 2
    localizationValues:
    - Press once to drop the ball
    - "\u041D\u0430\u0436\u043C\u0438 \u043D\u0430 \u044D\u043A\u0440\u0430\u043D
      \u043E\u0434\u0438\u043D \u0440\u0430\u0437, \u0447\u0442\u043E\u0431\u044B
      \u0441\u0431\u0440\u043E\u0441\u0438\u0442\u044C \u0448\u0430\u0440"
  - localizationKey: 3
    localizationValues:
    - Hold Your Finger
    - "\u0417\u0430\u0434\u0435\u0440\u0436\u0438 \u041F\u0430\u043B\u0435\u0446"
  - localizationKey: 4
    localizationValues:
    - Hold your finger to enter Slow Motion, it helps aiming
    - "\u0417\u0430\u0434\u0435\u0440\u0436\u0438 \u043F\u0430\u043B\u0435\u0446,
      \u0447\u0442\u043E\u0431\u044B \u043D\u0430\u0447\u0430\u0442\u044C \u0437\u0430\u043C\u0435\u0434\u043B\u0435\u043D\u0438\u0435
      \u0432\u0440\u0435\u043C\u0435\u043D\u0438"
  - localizationKey: 5
    localizationValues:
    - Buy Rainbow Ball
    - "\u041A\u0443\u043F\u0438 \u0420\u0430\u0434\u0443\u0436\u043D\u044B\u0439
      \u0428\u0430\u0440"
  - localizationKey: 6
    localizationValues:
    - It works with ball of ANY color!
    - "\u0420\u0430\u0434\u0443\u0436\u043D\u044B\u0439 \u0428\u0430\u0440 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
      \u0441 \u0448\u0430\u0440\u043E\u043C \u041B\u042E\u0411\u041E\u0413\u041E
      \u0446\u0432\u0435\u0442\u0430!"
